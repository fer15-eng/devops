pipeline {
    agent any

    stages {
        stage('Build') {
            steps {
                echo 'Building...'
                // Add your actual build commands here
                // Example: mvn package OR npm run build
            }
        }

        stage('Test') {
            steps {
                echo 'Testing...'
                // Add your test commands here
                // Example: mvn test OR npm test
            }
        }

        stage('Deploy to S3') {
            steps {
                withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-s3-creds']]) {
                    sh '''
                        # Upload everything from the Jenkins workspace "Sha" folder to your S3 bucket
                        aws s3 cp /var/lib/jenkins/workspace/Sha/ s3://shapipe/ --recursive
                    '''
                }
            }
        }
    }
}
